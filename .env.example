APP_NAME=GoEvoli
# development | production
APP_ENV=development

BACKEND_PORT=8080

# In production: set to your actual frontend domain (e.g. https://goevoli.example.com)
FRONTEND_URL=http://localhost:5173

# MongoDB connection string
# Local:   mongodb://localhost:27017
# Docker:  mongodb://mongodb:27017
# Atlas:   mongodb+srv://<user>:<password>@cluster.mongodb.net
MONGO_URI=mongodb://localhost:27017
MONGO_DATABASE=goevoli

# JWT secret – change this to a long random string in production!
JWT_SECRET=change-me-in-production

COOKIE_NAME=goevoli_session
# Set to true in production (requires HTTPS)
COOKIE_SECURE=false
# Lax | Strict | None (None requires COOKIE_SECURE=true)
COOKIE_SAME_SITE=Lax
